{
  "compilerOptions": {
    "baseUrl": "./src",
    "jsx": "react-jsx",
    "paths": {
      "~assets/*": [
        "assets/*"
      ],
      "~components/*": [
        "components/*"
      ],
      "~screens/*": [
        "screens/*"
      ],
      "~navigation/*": [
        "navigation/*"
      ],
      "~store/*": [
        "store/*"
      ],
      "~types/*": [
        "types/*"
      ],
      "~utils/*": [
        "utils/*"
      ],
      "~hooks/*": [
        "hooks/*"
      ],
      "~widgets/*": [
        "widgets/*"
      ],
      "~data/*": [
        "data/*"
      ]
    }
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "App.js"
  ]
}
